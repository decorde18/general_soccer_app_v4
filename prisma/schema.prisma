}

model games {
  id                                                   Int                          @id @default(autoincrement())
  season_id                                            Int
  timezone_label                                       String?                      @db.VarChar(10)
  home_team_season_id                                  Int
  away_team_season_id                                  Int
  status                                               games_status?                @default(scheduled)
  game_type                                            games_game_type?             @default(league)
  notes                                                String?                      @db.Text
  created_at                                           DateTime?                    @default(now()) @db.DateTime(0)
  modified_at                                           DateTime?                    @default(now()) @db.DateTime(0)
  default_reg_periods                                  Int                          @default(2) @db.TinyInt
  period_duration                                      Int                          @default(2400)
  ot_if_tied                                           Boolean                      @default(false)
  ot_duration                                          Int                          @default(600)
  so_if_tied                                           Boolean                      @default(true)
  video_link                                           String?                      @db.VarChar(500)
  location_id                                          Int?
  google_cal_id                                        String?                      @db.VarChar(255)
  sublocation_id                                       Int?
  start_date                                           DateTime                     @db.Date
  start_time                                           DateTime?                    @db.Time(0)
  end_date                                             DateTime?                    @db.Date
  end_time                                             DateTime?                    @db.Time(0)
  game_events_major                                    game_events_major[]
  game_events_penalties                                game_events_penalties[]
  game_events_player_actions                           game_events_player_actions[]
  game_events_team                                     game_events_team[]
  game_league_nodes                                    game_league_nodes[]
  game_periods                                         game_periods[]
  game_standings_inclusions                            game_standings_inclusions[]
  game_subs                                            game_subs[]
  team_seasons_games_away_team_season_idToteam_seasons team_seasons                 @relation("games_away_team_season_idToteam_seasons", fields: [away_team_season_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_games_away_team_season")
  team_seasons_games_home_team_season_idToteam_seasons team_seasons                 @relation("games_home_team_season_idToteam_seasons", fields: [home_team_season_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_games_home_team_season")
  locations                                            locations?                   @relation(fields: [location_id], references: [id], onUpdate: Restrict, map: "fk_games_location")
  seasons                                              seasons                      @relation(fields: [season_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_games_season")
  locations_sublocations                               locations_sublocations?      @relation(fields: [sublocation_id], references: [id], onUpdate: Restrict, map: "fk_games_sublocation")
  games_overtimes                                      games_overtimes[]
  player_games                                         player_games[]

  @@index([away_team_season_id], map: "fk_games_away_team_season")
  @@index([home_team_season_id], map: "fk_games_home_team_season")
  @@index([location_id], map: "fk_games_location")
  @@index([season_id], map: "fk_games_season")
  @@index([sublocation_id], map: "fk_games_sublocation")
}

model games_overtimes {
  id                   Int       @id @default(autoincrement())
  game_id              Int
  ot_1                 Int?      @db.TinyInt
  so_if_tied           Boolean?
  ot_if_tied           Boolean?
  min_ot_periods       Int?      @db.TinyInt
  max_ot_periods       Int?      @db.TinyInt
  default_ot_1_minutes Int?      @db.TinyInt
  default_ot_2_periods Int?      @db.TinyInt
  created_at           DateTime? @default(now()) @db.DateTime(0)
  modified_at          DateTime? @default(now()) @db.DateTime(0)
  games                games     @relation(fields: [game_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_games_overtimes_game")

  @@index([game_id], map: "fk_games_overtimes_game")
}

model governing_bodies {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(255)
  abbreviation String?   @db.VarChar(50)
  website      String?   @db.VarChar(255)
  created_at   DateTime? @default(now()) @db.Timestamp(0)
  modified_at  DateTime? @default(now()) @db.Timestamp(0)
  leagues      leagues[]
}

model league_node_seasons {
  id                      Int                        @id @default(autoincrement())
  league_node_id          Int
  season_id               Int
  start_date              DateTime?                  @db.Date
  end_date                DateTime?                  @db.Date
  status                  league_node_seasons_status @default(active)
  is_active               Boolean?                   @default(true)
  created_at              DateTime?                  @default(now()) @db.Timestamp(0)
  modified_at             DateTime?                  @default(now()) @db.Timestamp(0)
  game_league_nodes       game_league_nodes[]
  league_nodes            league_nodes               @relation(fields: [league_node_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_ln_season_node")
  seasons                 seasons                    @relation(fields: [season_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_ln_season_season")
  team_league_enrollments team_league_enrollments[]

  @@unique([league_node_id, season_id], map: "unique_node_season")
  @@index([season_id], map: "fk_ln_season_season")
}

model league_nodes {
  id                        Int                         @id @default(autoincrement())
  league_id                 Int
  parent_id                 Int?
  name                      String                      @db.VarChar(255)
  node_type                 league_nodes_node_type
  level                     Int?                        @default(0)
  display_order             Int?                        @default(0)
  start_date                DateTime?                   @db.Date
  end_date                  DateTime?                   @db.Date
  created_at                DateTime?                   @default(now()) @db.Timestamp(0)
  modified_at               DateTime?                   @default(now()) @db.Timestamp(0)
  game_standings_inclusions game_standings_inclusions[]
  league_node_seasons       league_node_seasons[]
  leagues                   leagues                     @relation(fields: [league_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_league_nodes_league")
  league_nodes              league_nodes?               @relation("league_nodesToleague_nodes", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "league_nodes_ibfk_1")
  other_league_nodes        league_nodes[]              @relation("league_nodesToleague_nodes")

  @@index([league_id], map: "fk_league_nodes_league")
  @@index([parent_id], map: "parent_id")
}

model leagues {
  id                Int               @id @default(autoincrement())
  name              String            @db.VarChar(255)
  abbreviation      String?           @db.VarChar(20)
  governing_body_id Int?
  status            leagues_status    @default(active)
  is_active         Boolean?
  created_at        DateTime?         @default(now()) @db.Timestamp(0)
  modified_at       DateTime?         @db.DateTime(0)
  description       String?           @db.Text
  is_tournament     Boolean?          @default(false)
  period_duration   Int?
  reg_periods       Int?
  ot_if_tied        Boolean?
  ot_duration       Int?
  so_if_tied        Boolean?
  league_nodes      league_nodes[]
  governing_bodies  governing_bodies? @relation(fields: [governing_body_id], references: [id], onUpdate: Restrict, map: "fk_leagues_governing_body")

  @@index([governing_body_id], map: "fk_leagues_governing_body")
}

model locations {
  id                     Int                      @id @default(autoincrement())
  name                   String                   @db.VarChar(255)
