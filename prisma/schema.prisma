  shooter_jersey_number                                                   Int?
  games                                                                   games?                        @relation(fields: [game_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_penalties_game")
  player_games_game_events_penalties_gk_player_game_idToplayer_games      player_games?                 @relation("game_events_penalties_gk_player_game_idToplayer_games", fields: [gk_player_game_id], references: [id], onUpdate: Restrict, map: "fk_penalties_gk")
  game_events_goals                                                       game_events_goals?            @relation(fields: [goal_id], references: [id], onUpdate: Restrict, map: "fk_penalties_goal")
  game_events_major                                                       game_events_major?            @relation(fields: [major_event_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_penalties_major")
  player_games_game_events_penalties_shooter_player_game_idToplayer_games player_games?                 @relation("game_events_penalties_shooter_player_game_idToplayer_games", fields: [shooter_player_game_id], references: [id], onUpdate: Restrict, map: "fk_penalties_shooter")
  team_seasons                                                            team_seasons                  @relation(fields: [team_season_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_penalties_team")

  @@index([game_id], map: "idx_penalties_game")
  @@index([gk_player_game_id], map: "idx_penalties_gk")
  @@index([goal_id], map: "idx_penalties_goal")
  @@index([major_event_id], map: "idx_penalties_major")
  @@index([shooter_player_game_id], map: "idx_penalties_shooter")
  @@index([is_shootout, shootout_round], map: "idx_penalties_shootout")
