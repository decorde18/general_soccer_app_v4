model game_league_nodes {
  game_id             Int
  league_node_id      Int
  is_primary          Boolean             @default(true)
  league_node_seasons league_node_seasons @relation(fields: [league_node_id], references: [id], onDelete: Cascade, map: "fk_game_league_nodes_season")
  games               games               @relation(fields: [game_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "game_league_nodes_ibfk_1")

  @@id([game_id, league_node_id])
  @@index([league_node_id], map: "fk_game_league_nodes_season")
}

model game_periods {
  id            Int       @id @default(autoincrement())
  game_id       Int
  period_number Int
  start_time    BigInt?
  end_time      BigInt?
  created_at    DateTime? @default(now()) @db.DateTime(0)
  modified_at   DateTime? @default(now()) @db.DateTime(0)
  games         games     @relation(fields: [game_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "game_periods_ibfk_1")

  @@unique([game_id, period_number], map: "game_id")
}


model game_standings_inclusions {
  id                   Int          @id @default(autoincrement())
  game_id              Int
  league_node_id       Int
  counts_for_standings Boolean?     @default(true)
  created_at           DateTime?    @default(now()) @db.Timestamp(0)
  modified_at          DateTime?    @default(now()) @db.Timestamp(0)
  games                games        @relation(fields: [game_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "game_standings_inclusions_ibfk_1")
  league_nodes         league_nodes @relation(fields: [league_node_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "game_standings_inclusions_ibfk_2")

  @@unique([game_id, league_node_id], map: "unique_game_league")
  @@index([league_node_id], map: "league_node_id")
}

