generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model addresses {
  id            Int         @id @default(autoincrement())
  address_line1 String?     @db.VarChar(255)
  address_line2 String?     @db.VarChar(255)
  city          String?     @db.VarChar(100)
  state         String?     @db.VarChar(50)
  postal_code   String?     @db.VarChar(20)
  country       String?     @default("USA") @db.VarChar(100)
  created_at    DateTime?   @default(now()) @db.Timestamp(0)
  modified_at   DateTime?   @default(now()) @db.Timestamp(0)
  clubs         clubs[]
  locations     locations[]
  
}

model age_groups {
  id                      Int            @id @default(autoincrement())
  name                    String         @db.VarChar(50)
  begin_date              DateTime?      @db.Date
  end_date                DateTime?      @db.Date
  default_period_duration Int?           @default(2400)
  default_ot_if_tied      Boolean?       @default(false)
  default_ot_duration     Int?           @default(600)
  default_so_if_tied      Boolean?       @default(true)
  team_seasons            team_seasons[]
}

model club_staff {
  id          Int             @id @default(autoincrement())
  person_id   Int
  club_id     Int
  role        club_staff_role
  is_active   Boolean?        @default(true)
  joined_date DateTime?       @db.Date
  left_date   DateTime?       @db.Date
  created_at  DateTime?       @default(now()) @db.DateTime(0)
  modified_at DateTime?       @default(now()) @db.DateTime(0)
  people      people          @relation(fields: [person_id], references: [id], onUpdate: Restrict, map: "club_staff_ibfk_1")
  clubs       clubs           @relation(fields: [club_id], references: [id], onUpdate: Restrict, map: "club_staff_ibfk_2")

  @@unique([person_id, club_id, role], map: "unique_person_club_role")
  @@index([club_id], map: "idx_club_staff_club")
  @@index([person_id], map: "idx_club_staff_person")
}

model clubs {
  id           Int          @id @default(autoincrement())
  name         String       @db.VarChar(100)
  location     String?      @db.VarChar(100)
  logo_url     String?      @db.VarChar(255)
  founded_year Int?
  contact_info String?      @db.Text
  created_at   DateTime?    @default(now()) @db.DateTime(0)
  modified_at  DateTime?    @default(now()) @db.DateTime(0)
  is_active    Boolean      @default(true)
  abbreviation String?      @db.VarChar(20)
  type         clubs_type?  @default(club)
  location_id  Int?
  club_staff   club_staff[]
  addresses    addresses?   @relation(fields: [location_id], references: [id], map: "fk_clubs_location")
  teams        teams[]

  @@index([location_id], map: "fk_clubs_location")
}

model event_types {
  id          Int                   @id @default(autoincrement())
  name        String                @db.VarChar(100)
  category    event_types_category? @default(other)
  created_at  DateTime?             @default(now()) @db.Timestamp(0)
  modified_at DateTime?             @default(now()) @db.Timestamp(0)
  events      events[]
}

model events {
  id              Int           @id @default(autoincrement())
  created_at      DateTime?     @default(now()) @db.Timestamp(0)
  modified_at     DateTime?     @default(now()) @db.Timestamp(0)
  start_datetime  DateTime      @db.DateTime(0)
  end_datetime    DateTime      @db.DateTime(0)
  is_all_day      Boolean?      @default(false)
  title           String        @db.VarChar(255)
  description     String?       @db.Text
  recurrence_rule String?       @db.Text
  google_cal_id   String?       @db.VarChar(255)
  team_season_id  Int?
  event_type_id   Int?
  location_id     Int?
  video_link      String?       @db.VarChar(500)
  event_types     event_types?  @relation(fields: [event_type_id], references: [id], onUpdate: Restrict, map: "events_ibfk_2")
  locations       locations?    @relation(fields: [location_id], references: [id], onUpdate: Restrict, map: "events_ibfk_3")
  team_seasons    team_seasons? @relation(fields: [team_season_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_events_team_season")

  @@index([event_type_id], map: "event_type_id")
  @@index([team_season_id], map: "fk_events_team_season")
  @@index([location_id], map: "location_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model game_events_discipline {
  id                     Int                              @id @default(autoincrement())
  major_event_id         Int
  team_season_id         Int
  player_game_id         Int?
  opponent_jersey_number Int?
  card_type              game_events_discipline_card_type
  card_reason            String?                          @db.Text
  created_at             DateTime?                        @default(now()) @db.Timestamp(0)
  modified_at            DateTime?                        @default(now()) @db.Timestamp(0)
  game_events_major      game_events_major                @relation(fields: [major_event_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_discipline_major")
  player_games           player_games?                    @relation(fields: [player_game_id], references: [id], onUpdate: Restrict, map: "fk_discipline_player")
  team_seasons           team_seasons                     @relation(fields: [team_season_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_discipline_team")

  @@index([card_type], map: "idx_discipline_card_type")
  @@index([major_event_id], map: "idx_discipline_major")
  @@index([player_game_id], map: "idx_discipline_player")
  @@index([team_season_id], map: "idx_discipline_team")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model game_events_goals {
  id                                                                       Int                     @id @default(autoincrement())
  major_event_id                                                           Int
  team_season_id                                                           Int
  scorer_player_game_id                                                    Int?
  opponent_jersey_number                                                   Int?
  assist_player_game_id                                                    Int?
  defending_gk_player_game_id                                              Int?
  is_own_goal                                                              Boolean                 @default(false)
  goal_types                                                               String?                 @db.LongText
  created_at                                                               DateTime?               @default(now()) @db.Timestamp(0)
  modified_at                                                              DateTime?               @default(now()) @db.Timestamp(0)
  player_games_game_events_goals_assist_player_game_idToplayer_games       player_games?           @relation("game_events_goals_assist_player_game_idToplayer_games", fields: [assist_player_game_id], references: [id], onUpdate: Restrict, map: "fk_goals_assist")
  player_games_game_events_goals_defending_gk_player_game_idToplayer_games player_games?           @relation("game_events_goals_defending_gk_player_game_idToplayer_games", fields: [defending_gk_player_game_id], references: [id], onUpdate: Restrict, map: "fk_goals_gk")
  game_events_major                                                        game_events_major       @relation(fields: [major_event_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_goals_major")
  player_games_game_events_goals_scorer_player_game_idToplayer_games       player_games?           @relation("game_events_goals_scorer_player_game_idToplayer_games", fields: [scorer_player_game_id], references: [id], onUpdate: Restrict, map: "fk_goals_scorer")
  team_seasons                                                             team_seasons            @relation(fields: [team_season_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_goals_team")
  game_events_penalties                                                    game_events_penalties[]

  @@index([assist_player_game_id], map: "idx_goals_assist")
  @@index([defending_gk_player_game_id], map: "idx_goals_gk")
  @@index([major_event_id], map: "idx_goals_major")
  @@index([scorer_player_game_id], map: "idx_goals_scorer")
  @@index([team_season_id], map: "idx_goals_team")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model game_events_major {
  id                     Int                          @id @default(autoincrement())
  game_id                Int
  event_type             game_events_major_event_type
  game_time              Int
  end_time               Int?
  period                 Int
  clock_should_run       Boolean                      @default(true)
  details                String?                      @db.Text
  created_at             DateTime?                    @default(now()) @db.Timestamp(0)
  modified_at            DateTime?                    @default(now()) @db.Timestamp(0)
  game_events_discipline game_events_discipline[]
  game_events_goals      game_events_goals[]
  games                  games                        @relation(fields: [game_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_major_game")
  game_events_penalties  game_events_penalties[]

  @@index([game_id], map: "idx_major_game")
  @@index([game_id, period, game_time], map: "idx_major_time")
  @@index([event_type], map: "idx_major_type")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
